# Environment Variables for yesitsme
# Copy this file to .env and fill in your values

# Instagram session ID (required)
# To get your session ID:
# 1. Log in to Instagram in your browser
# 2. Open Developer Tools (F12)
# 3. Go to Storage/Application tab
# 4. Find cookies for instagram.com
# 5. Copy the sessionid value
INSTAGRAM_SESSION_ID=your_session_id_here

# Optional: Timeout between requests (seconds)
# YESITSME_TIMEOUT=10

# Optional: Proxy configuration
# YESITSME_PROXY=http://user:pass@proxy.example.com:8080

# Optional: Maximum retry attempts
# YESITSME_MAX_RETRIES=3

# Optional: Verbose output
# YESITSME_VERBOSE=false
